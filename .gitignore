grid_stderr.txt
cho_stderr.txt
benchmarks/electrolyte/electrolyte_stderr.txt
benchmarks/grid/grid_stderr.txt
benchmarks/cho/cho_stderr.txt

# nlp problems — vendored nlpbench clone is private (GAMS-licensed); keep
