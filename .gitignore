# from inside the manuscript/ directory and should never be committed.
manuscript/*.tex
manuscript/*.pdf
manuscript/*.html
manuscript/*.synctex.gz
manuscript/_minted/
manuscript/*.pyg
manuscript/*.bbl
manuscript/*.blg

